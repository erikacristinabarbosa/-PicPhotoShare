# ==========================================
# Variáveis do Google Drive
# ==========================================
# Client ID e Secret do projeto do Google Cloud
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Refresh token obtido via OAuth2 Playground (necessário para acesso offline)
GOOGLE_REFRESH_TOKEN=
# ID da pasta no Google Drive onde as mídias serão salvas
GOOGLE_DRIVE_FOLDER_ID=

# ==========================================
# Variáveis do Twilio (Recuperação de PIN - opcional)
# ==========================================
# Configurações para envio de SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de telefone do remetente (comprado ou gerado no Twilio)
TWILIO_PHONE_NUMBER=

# ==========================================
# Variáveis da Plataforma (AI Studio / Deploy)
# ==========================================
# Chave da API do Gemini (caso utilize IA no projeto)
GEMINI_API_KEY=
# URL onde o App está hospedado (ex: https://meusite.com)
APP_URL=

